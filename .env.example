# Required for GPT-4o experiment backbones and judge evaluation.
OPENAI_API_KEY=sk-...

# Used when running a local vLLM OpenAI-compatible endpoint.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

LOG_LEVEL=INFO

# Optional overrides for benchmark inputs.
SCISAFETYBENCH_RESEARCH_TASKS=data/scisafetybench/tasks_research.json
SCISAFETYBENCH_TOOL_TASKS=data/scisafetybench/tasks_tool.json
SCISAFETYBENCH_TOOL_REGISTRY=data/scisafetybench/tool_registry.json
SCISAFETYBENCH_TOOL_API_SPECS=data/scisafetybench/tool_api_specs.json
