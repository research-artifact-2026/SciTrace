# OpenAI API key (required for GPT-4o backbone and evaluation judge)
OPENAI_API_KEY=sk-...

# vLLM server configuration
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# Logging (stdout only; run artifacts go under data/results/runs/)
LOG_LEVEL=INFO

# Benchmark data paths (defaults shown)
SCISAFETYBENCH_RESEARCH_TASKS=data/benchmark/scisafetybench/tasks_research.json
SCISAFETYBENCH_TOOL_TASKS=data/benchmark/scisafetybench/tasks_tool.json
SCISAFETYBENCH_TOOL_REGISTRY=data/benchmark/scisafetybench/tool_registry.json
