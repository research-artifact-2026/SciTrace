{
  "experiment_name": "llama31_70b_bare",
  "description": "Bare LLM: four-stage SafeScientist workflow without safety modules on meta-llama/Llama-3.1-70B-Instruct",
  "backbone": {
    "backbone_type": "vllm",
    "model_name": "meta-llama/Llama-3.1-70B-Instruct",
    "temperature": 0.1,
    "top_p": 0.9,
    "top_k": 50,
    "repetition_penalty": 1.05,
    "max_tokens": 4096,
    "base_url": "http://localhost:8000/v1",
    "quantization": "awq",
    "tensor_parallel_size": 2,
    "dtype": "bfloat16"
  },
  "method": "bare",
  "sir": {
    "enabled": false,
    "k_checks": 3
  },
  "ctv": {
    "enabled": false,
    "block_threshold": 0.5,
    "weights": {
      "w1": 0.4,
      "w2": 0.4
    }
  },
  "fallback_filters": {
    "enabled": true
  },
  "reviewer": {
    "enabled": true,
    "uses_cumulative_state": false
  },
  "benchmark": {
    "task_types": [
      "research",
      "tool"
    ],
    "domains": [
      "Biology",
      "Chemistry",
      "Physics",
      "Medicine",
      "Information Science",
      "Material Science"
    ],
    "n_research_tasks": 240,
    "n_tool_tasks": 120
  },
  "evaluation": {
    "judge_model": "gpt-4o",
    "metrics": [
      "safety_score",
      "reject_rate",
      "tool_call_safety_rate",
      "quality",
      "clarity",
      "overall"
    ],
    "judge_temperature": 0.0,
    "temperature": 0.0,
    "max_tokens": 4096
  },
  "output_dir": "data/results/runs/llama31_70b_bare/",
  "seed": 42
}
